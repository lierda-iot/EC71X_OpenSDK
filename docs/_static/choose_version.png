<svg xmlns="http://www.w3.org/2000/svg" width="400" height="150" viewBox="0 0 400 150">
  <rect fill="#fff" width="400" height="150" stroke="#ddd" stroke-width="2"/>
  <text fill="#333" font-family="Arial" font-size="18" font-weight="bold" text-anchor="middle" x="200" y="40">Version Selection</text>
  <rect fill="#fff3e0" x="50" y="60" width="100" height="40" rx="5"/>
  <text fill="#E65100" font-family="Arial" font-size="14" text-anchor="middle" x="100" y="85">latest</text>
  <rect fill="#fff3e0" x="160" y="60" width="80" height="40" rx="5"/>
  <text fill="#E65100" font-family="Arial" font-size="14" text-anchor="middle" x="200" y="85">v1.0</text>
  <rect fill="#fff3e0" x="250" y="60" width="80" height="40" rx="5"/>
  <text fill="#E65100" font-family="Arial" font-size="14" text-anchor="middle" x="290" y="85">v0.9</text>
  <text fill="#999" font-family="Arial" font-size="12" text-anchor="middle" x="200" y="130">Select documentation version</text>
</svg>
